<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.optionsowl.harvester-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/kody/dev/options-owl/scripts/harvester-sync.sh</string>
    </array>

    <!-- Run every Saturday at 8:00 AM local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>6</integer>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/kody/dev/options-owl/journal/harvester_sync_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kody/dev/options-owl/journal/harvester_sync_stderr.log</string>

    <!-- Don't run if laptop was asleep — catch up on next wake -->
    <key>MissedTaskPolicy</key>
    <string>Merge</string>

    <key>WorkingDirectory</key>
    <string>/Users/kody/dev/options-owl</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>/Users/kody</string>
    </dict>
</dict>
</plist>
